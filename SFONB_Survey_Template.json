    {
      "parameters": {
        "fromEmail": "<YOUR_SENDER_EMAIL>",
        "toEmail": "={{ $json.email }}",
        "subject": "={{ $json.subject }}",
        "html": "=<div style=\"background-color:#f4f6f8;padding:30px 0;font-family:Arial,Helvetica,sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#ffffff;border-radius:8px;padding:30px;\">\n          \n          <!-- Header -->\n          <tr>\n            <td style=\"font-size:20px;font-weight:bold;color:#333333;padding-bottom:20px;\">\n              We’d love your feedback 💬\n            </td>\n          </tr>\n\n          <!-- Body -->\n          <tr>\n            <td style=\"font-size:14px;color:#444444;line-height:1.6;padding-bottom:20px;\">\n              Hi <strong>{{ $json.firstName }}</strong>,<br><br>\n\n              Thank you for your application. We truly appreciate the time and effort you put into it.<br><br>\n\n              To help us improve our recruitment experience, we’d love to hear your feedback by completing a short survey.\n            </td>\n          </tr>\n\n          <!-- CTA Button -->\n          <tr>\n            <td align=\"center\" style=\"padding:20px 0;\">\n              <a href=\"{{ $json.SurveyLink }}\"\n                 style=\"background-color:#2563eb;color:#ffffff;\n                        text-decoration:none;padding:12px 24px;\n                        border-radius:6px;font-size:14px;\n                        display:inline-block;\">\n                Take the Survey\n              </a>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"font-size:12px;color:#777777;line-height:1.6;padding-top:20px;border-top:1px solid #eeeeee;\">\n              Best regards,<br>\n              <strong>HR Team</strong><br><br>\n\n              <span style=\"color:#aaaaaa;\">\n                This email was sent automatically. Please do not reply.\n              </span>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</div>",
        "options": {}
      },
