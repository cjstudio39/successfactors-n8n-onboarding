    {
      "parameters": {
        "content": "\n## SAP SuccessFactors → Onboarding Survey + Telegram Alert\nTriggered by SF Integration Center when a candidate completes their onboarding document signature. Sends the candidate a pre-filled Google Form survey email and alerts your HR Telegram group that the record is waiting in Manage Pending Hire.\n\n**Requirements:** SuccessFactors with Integration Center · SMTP or Gmail credential · Telegram bot (via @BotFather) · a Google Form",
        "width": 992
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -336,
        48
      ],
      "id": "996d7dc9-5c5e-47a1-aaf0-1cdf0d73163a",
      "name": "Sticky Note"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\nconst email = body.Email;\nconst firstName = body.FirstName;\nconst lastName = body.LastName;\n\nreturn [\n  {\n    json: {\n      email,\n      firstName,\n      lastName,\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
